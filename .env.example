# Vaulter Proximity Mapper — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# Google Places API key (optional — OSM is used as free fallback if not set)
# Get one at: https://console.cloud.google.com → Places API → Credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
